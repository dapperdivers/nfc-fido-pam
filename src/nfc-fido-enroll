#!/usr/bin/python3
# Absolute system interpreter on purpose (see nfc-fido-verify for why).
"""nfc-fido-enroll - enrol a FIDO2 NFC authenticator for nfc-fido-pam.

Registers a fresh non-resident FIDO2 credential on the tapped authenticator (e.g.
an NFC implant) and writes the public half to the enrollment store that
nfc-fido-verify checks. Run as root (the store lives under /etc).

  sudo nfc-fido-enroll --user alice
  # tap the implant when prompted

Store record (JSON, one file per user at <store-dir>/<user>, mode 0644 root):
  { "rp_id": ..., "cred_id": base64, "pubkey": base64(cbor(COSE key)) }
Only public data is stored - the private key never leaves the authenticator.
"""

import argparse
import base64
import hashlib
import json
import os
import pwd
import sys
import time

DEFAULT_STORE_DIR = "/etc/nfc-fido"
DEFAULT_RP_ID = "nfc-pam"
DEFAULT_TIMEOUT = 20.0


def die(msg, code=1):
    print("nfc-fido-enroll: %s" % msg, file=sys.stderr)
    sys.exit(code)


def find_device(timeout):
    from fido2.pcsc import CtapPcscDevice
    end = time.time() + timeout
    first = True
    while first or time.time() < end:
        first = False
        try:
            devs = list(CtapPcscDevice.list_devices())
            if devs:
                return devs[0]
        except Exception:
            pass
        if time.time() >= end:
            break
        time.sleep(0.3)
    return None


def main():
    p = argparse.ArgumentParser(
        prog="nfc-fido-enroll",
        description="Enrol a FIDO2 NFC authenticator for nfc-fido-pam.")
    p.add_argument("--user", required=True, help="local user to enrol the implant for")
    p.add_argument("--timeout", type=float, default=DEFAULT_TIMEOUT,
                   help="seconds to wait for a tap (default: %(default)s)")
    p.add_argument("--store-dir", default=DEFAULT_STORE_DIR,
                   help="enrollment store directory (default: %(default)s)")
    p.add_argument("--rp-id", default=DEFAULT_RP_ID,
                   help="FIDO relying-party id (default: %(default)s); must match the verifier")
    p.add_argument("--force", action="store_true", help="overwrite an existing enrollment")
    args = p.parse_args()

    try:
        pwd.getpwnam(args.user)
    except KeyError:
        die("no such local user: %r" % args.user)

    if os.geteuid() != 0:
        die("must run as root to write %s" % args.store_dir)

    try:
        from fido2.ctap2 import Ctap2
        from fido2 import cbor
    except Exception as e:
        die("python-fido2 not available: %r (install python3-fido2 / python3-pyscard)" % e)

    store = os.path.join(args.store_dir, args.user)
    if os.path.exists(store) and not args.force:
        die("%s already exists; pass --force to overwrite" % store)

    print("Tap the implant on the reader (waiting up to %gs)..." % args.timeout, flush=True)
    dev = find_device(args.timeout)
    if dev is None:
        die("no authenticator detected - is pcscd running and the reader present?", 2)

    ctap = Ctap2(dev)
    client_data_hash = os.urandom(32)
    rp = {"id": args.rp_id, "name": args.rp_id}
    user = {"id": hashlib.sha256(args.user.encode()).digest(), "name": args.user}
    key_params = [{"type": "public-key", "alg": -7}]  # ES256
    try:
        # Non-resident credential (rk off): we store the credential id ourselves.
        att = ctap.make_credential(client_data_hash, rp, user, key_params,
                                   options={"rk": False})
    except Exception as e:
        die("make_credential failed: %r" % e, 3)

    cred = att.auth_data.credential_data
    rec = {
        "rp_id": args.rp_id,
        "cred_id": base64.b64encode(cred.credential_id).decode(),
        "pubkey": base64.b64encode(cbor.encode(cred.public_key)).decode(),
    }

    os.makedirs(args.store_dir, mode=0o755, exist_ok=True)
    os.chmod(args.store_dir, 0o755)
    tmp = store + ".tmp"
    with open(tmp, "w") as f:
        json.dump(rec, f)
    os.chmod(tmp, 0o644)
    os.replace(tmp, store)
    print("Enrolled %s -> %s" % (args.user, store))
    print("Test it:  nfc-fido-verify --user %s --timeout 15  (tap; expect exit 0)" % args.user)


if __name__ == "__main__":
    main()
