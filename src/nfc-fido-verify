#!/usr/bin/python3
# SPDX-License-Identifier: GPL-2.0-only
# NOTE: absolute system interpreter on purpose - a PAM helper must not inherit a
# user's pyenv/venv shim (which won't have python-fido2/pyscard). Debian ships
# python3 at /usr/bin/python3; adjust at package build time for other distros.
"""nfc-fido-verify - verify a FIDO2 NFC authenticator over PC/SC (nfc-fido-pam, Layer 2).

Polls a PC/SC reader for a FIDO2 authenticator (e.g. an NFC implant), performs a
fresh-challenge CTAP2 get_assertion against the credential enrolled for a user,
and signals the result via its exit code. This is a *standalone* verifier: it does
the device + crypto work in a normal system process where libfido2/pyscard/libssl
resolve cleanly, so a PAM client that cannot do PC/SC in-process (e.g. a Nix-built
lock screen on a non-NixOS host) can still authenticate by simply invoking it.

It is the privilege/environment-separated helper of the nfc-fido-pam stack, in the
same spirit as pam_unix -> unix_chkpwd or pam_u2f -> pamu2fcfg.

Exit codes:
  0  verified   implant present and assertion valid           -> PAM auth success
  1  failed     implant present but assertion/verify failed    -> fall through
  2  absent     no implant detected, or user not enrolled      -> fall through
  3  error      internal error (unreadable store, missing libs)-> fall through

Wire it into PAM with the stock pam_exec module, e.g.:

  auth  sufficient  pam_exec.so  quiet  /usr/lib/nfc-fido/nfc-fido-verify --pam --timeout 3

With `sufficient`, any non-zero exit cleanly falls through to the next method
(fingerprint / password).
"""

import argparse
import base64
import hashlib
import json
import os
import pwd
import shutil
import subprocess
import sys
import time

# Exit codes (also the module's vocabulary).
OK, FAILED, ABSENT, ERROR = 0, 1, 2, 3

DEFAULT_STORE_DIR = "/etc/nfc-fido"
DEFAULT_RP_ID = "nfc-pam"
DEFAULT_TIMEOUT = 3.0

# COSE algorithms accepted for the enrolled key. Pinning to a known-good set
# defends a tampered store from substituting a weak/unexpected algorithm:
# -7 ES256, -35/-36 ES384/512, -8 EdDSA, -37/-38/-39 PS256/384/512, -257 RS256.
ALLOWED_ALGS = {-7, -35, -36, -8, -37, -38, -39, -257}


def store_is_safe(path):
    """True only if `path` and its parent dir are root-owned and not group/other-writable.

    The enrollment record is public data, but its *integrity* is what authorizes a
    credential: a writable store would let an attacker enrol their own key.
    """
    for p in (path, os.path.dirname(path)):
        try:
            st = os.stat(p)
        except OSError:
            return False
        if st.st_uid != 0 or (st.st_mode & 0o022):
            return False
    return True


def log(args, msg):
    """Diagnostics to stderr; silenced under --quiet (pam_exec passes `quiet`)."""
    if not args.quiet:
        print("nfc-fido-verify: %s" % msg, file=sys.stderr, flush=True)


def resolve_user(args):
    """Pick the target user: explicit --user, else $PAM_USER (set by pam_exec), else current."""
    if args.user:
        return args.user
    if args.pam and os.environ.get("PAM_USER"):
        return os.environ["PAM_USER"]
    return pwd.getpwuid(os.getuid()).pw_name


def authtok_typed():
    """True if a non-empty password was piped on stdin (pam_exec `expose_authtok`).

    Used with --skip-if-authtok so that *typing a password* skips the implant poll
    entirely (instant fall-through to pam_unix) while a bare submit still polls for
    a tap. The token is only tested for emptiness - never logged or used.
    """
    import select
    try:
        ready, _, _ = select.select([sys.stdin], [], [], 1.0)
        if not ready:
            return False
        data = sys.stdin.buffer.read()
    except Exception:
        return False
    # pam_exec writes the authtok terminated by NUL; treat anything non-blank as typed.
    return len(data.split(b"\x00", 1)[0].strip()) > 0


def _counter_state_path(args, user):
    """Where the per-credential signature-counter high-water mark lives.

    Defaults to a per-user path under the account's home (the verifier runs as the
    user under a lock screen, so this works unprivileged); root context uses
    /var/lib/nfc-fido. Override with --state-dir to point at a hardened location.
    """
    if args.state_dir:
        base = args.state_dir
    elif os.geteuid() == 0:
        base = "/var/lib/nfc-fido"
    else:
        try:
            home = pwd.getpwnam(user).pw_dir          # robust even if $HOME is unset under PAM
        except KeyError:
            home = os.path.expanduser("~")
        base = os.environ.get("XDG_STATE_HOME") or os.path.join(home, ".local", "state")
        base = os.path.join(base, "nfc-fido")
    return os.path.join(base, user + ".count")


def check_counter(args, user, presented):
    """WebAuthn 6.1.1 clone detection. Returns 'ok', 'clone', or 'skip'.

    Compares the assertion's signature counter to the stored high-water mark and
    advances it on a legitimate increase. A non-increasing *nonzero* counter is the
    spec's cloned-authenticator signal. A constant-0 counter (an authenticator with
    no counter support) is tolerated per spec - never treated as a clone.
    """
    if args.counter_policy == "off":
        return "ok"
    path = _counter_state_path(args, user)
    stored = None
    try:
        with open(path) as f:
            stored = int(f.read().strip())
    except (OSError, ValueError):
        stored = None
    if presented == 0 and (stored is None or stored == 0):
        _persist_counter(args, path, 0)               # first sight; no clone signal possible
        return "skip"
    if stored is None or presented > stored:
        _persist_counter(args, path, presented)
        return "ok"
    return "clone"                                     # presented <= stored: do NOT advance


def _persist_counter(args, path, value):
    """Best-effort atomic write of the high-water mark. A write failure warns but
    never fails authentication (an unprivileged deployment may not be able to persist)."""
    try:
        os.makedirs(os.path.dirname(path), mode=0o700, exist_ok=True)
        tmp = path + ".tmp"
        with open(tmp, "w") as f:
            f.write(str(value))
        os.replace(tmp, path)
    except OSError as e:
        log(args, "warning: could not persist signature counter to %s: %r" % (path, e))


def find_device(args, timeout):
    """Poll briefly for a FIDO authenticator on a PC/SC reader. Returns a device or None."""
    from fido2.pcsc import CtapPcscDevice
    end = time.time() + timeout
    first = True
    logged_exc = False
    while first or time.time() < end:
        first = False
        try:
            devs = list(CtapPcscDevice.list_devices())
            if devs:
                return devs[0]
        except Exception as e:
            if not logged_exc:
                logged_exc = True
                log(args, "PC/SC poll error (retrying): %r" % e)
        if time.time() >= end:
            break
        time.sleep(0.3)
    return None


def verify(args, user):
    """Returns one of OK / FAILED / ABSENT / ERROR for `user`."""
    store = os.path.join(args.store_dir, user)
    if not os.path.exists(store):
        log(args, "no implant enrolled for %r (looked in %s)" % (user, store))
        return ABSENT
    if not store_is_safe(store):
        log(args, "refusing %s: store must be root-owned and not group/other-writable" % store)
        return ERROR

    try:
        from fido2.ctap import CtapError
        from fido2.ctap2 import Ctap2
        from fido2.cose import CoseKey
        from fido2 import cbor
    except Exception as e:
        log(args, "fido2 library unavailable: %r" % e)
        return ERROR

    try:
        with open(store) as f:
            rec = json.load(f)
        cred_id = base64.b64decode(rec["cred_id"])
        pub = CoseKey.parse(cbor.decode(base64.b64decode(rec["pubkey"])))
    except Exception as e:
        log(args, "enrollment record %s is unreadable: %r" % (store, e))
        return ERROR

    # Pin the key algorithm (the COSE key carries its own alg; reject anything
    # outside the allow-list in case the store was tampered with).
    if pub.get(3) not in ALLOWED_ALGS:
        log(args, "enrolled key uses a disallowed algorithm: %r" % pub.get(3))
        return ERROR

    dev = find_device(args, args.timeout)
    if dev is None:
        log(args, "no implant detected within %gs" % args.timeout)
        return ABSENT

    challenge = os.urandom(32)
    allow = [{"type": "public-key", "id": cred_id}]
    # get_assertion can intermittently raise on non-canonical CBOR from some
    # authenticators (the ECDSA signature length varies between attempts). Retry
    # transient parse/comm errors while the token is still in the field, but treat
    # a CtapError (e.g. NO_CREDENTIALS for a non-enrolled token) as a definitive no.
    assertion = None
    deadline = time.time() + min(max(args.timeout, 1.0), 6.0)
    while assertion is None:
        try:
            assertion = Ctap2(dev).get_assertion(args.rp_id, challenge, allow)
        except CtapError as e:
            log(args, "get_assertion rejected by authenticator: %r" % e)
            return FAILED
        except Exception as e:
            if time.time() >= deadline:
                log(args, "get_assertion failed after retries: %r" % e)
                return FAILED
            time.sleep(0.2)
            redev = find_device(args, 1.0)
            if redev is not None:
                dev = redev

    auth_data = bytes(assertion.auth_data)
    # WebAuthn 7.2 step 16: rpIdHash binds the assertion to our relying-party id.
    if auth_data[:32] != hashlib.sha256(args.rp_id.encode()).digest():
        log(args, "relying-party hash mismatch")
        return FAILED
    flags = auth_data[32]
    # Step 17: User Present is an unconditional MUST for a (non-silent) assertion.
    if not (flags & 0x01):
        log(args, "user-presence (UP) flag not set")
        return FAILED
    # Step 18 (policy): require User Verification if asked (and supported by the token).
    if args.require_uv and not (flags & 0x04):
        log(args, "user-verification (UV) required but flag not set")
        return FAILED
    # Step 19: a credential cannot be backed-up (BS) without being backup-eligible (BE).
    if (flags & 0x10) and not (flags & 0x08):
        log(args, "invalid backup state: BS set without BE")
        return FAILED
    # Steps 1-5: bind to the requested credential. The authenticator MAY omit this
    # field when the allowList has exactly one entry (CTAP2 6.2) - omission is fine.
    cred = assertion.credential
    if cred is not None:
        cid = cred.get("id") if hasattr(cred, "get") else getattr(cred, "id", None)
        if cid != cred_id:
            log(args, "credential id mismatch")
            return FAILED
    # Step 23: signature over authData||clientDataHash, using the ENROLLED key/alg.
    try:
        pub.verify(auth_data + challenge, assertion.signature)
    except Exception:
        log(args, "signature verification failed")
        return FAILED

    # Step 24 / 6.1.1: signature-counter clone detection (only after the signature
    # is confirmed authentic, so the counter we trust came from a real assertion).
    sign_count = int.from_bytes(auth_data[33:37], "big")
    if check_counter(args, user, sign_count) == "clone":
        log(args, "signature counter %d did not increase vs stored; possible cloned authenticator"
            % sign_count)
        if args.counter_policy == "strict":
            return FAILED
    return OK


def beep(args, user):
    """Optional fire-and-forget success chime in the target user's audio session.

    Never blocks or affects the result; silently no-ops if it can't play.
    """
    if not args.success_sound:
        return
    try:
        pw = pwd.getpwnam(user)
    except Exception:
        return
    runtime = "/run/user/%d" % pw.pw_uid
    player = shutil.which("pw-play") or shutil.which("paplay") or shutil.which("aplay")
    if not player or not os.path.isdir(runtime) or not os.path.exists(args.success_sound):
        return
    env = {"XDG_RUNTIME_DIR": runtime, "HOME": pw.pw_dir, "PATH": "/usr/bin:/bin"}
    kwargs = dict(env=env, stdin=subprocess.DEVNULL, stdout=subprocess.DEVNULL,
                  stderr=subprocess.DEVNULL, close_fds=True)
    if os.geteuid() == 0 and os.getuid() != pw.pw_uid:
        def demote():
            os.setgid(pw.pw_gid)
            os.setuid(pw.pw_uid)
        kwargs["preexec_fn"] = demote
    try:
        subprocess.Popen([player, args.success_sound], **kwargs)
    except Exception:
        pass


def main():
    p = argparse.ArgumentParser(
        prog="nfc-fido-verify",
        description="Verify a FIDO2 NFC authenticator over PC/SC; exit 0 on success.")
    p.add_argument("--user", help="user to verify (default: $PAM_USER under --pam, else current user)")
    p.add_argument("--pam", action="store_true",
                   help="PAM/pam_exec mode: take the user from $PAM_USER and stay quiet")
    p.add_argument("--skip-if-authtok", action="store_true",
                   help="if a non-empty password is piped on stdin (pam_exec expose_authtok), "
                        "skip the implant poll and exit absent immediately (no delay on typed login)")
    p.add_argument("--timeout", type=float, default=DEFAULT_TIMEOUT,
                   help="seconds to look for the implant before giving up (default: %(default)s)")
    p.add_argument("--store-dir", default=DEFAULT_STORE_DIR,
                   help="enrollment store directory (default: %(default)s)")
    p.add_argument("--rp-id", default=DEFAULT_RP_ID,
                   help="FIDO relying-party id used at enrollment (default: %(default)s)")
    p.add_argument("--require-uv", action="store_true",
                   help="require the User Verified flag (only for tokens with a PIN/biometric; "
                        "a tap-only implant never sets UV, so leave this off for those)")
    p.add_argument("--counter-policy", choices=("strict", "warn", "off"), default="strict",
                   help="action on a non-increasing signature counter (clone signal): "
                        "strict=reject, warn=allow+log, off=disable (default: strict)")
    p.add_argument("--state-dir", default=None,
                   help="directory for the signature-counter high-water mark "
                        "(default: per-user ~/.local/state/nfc-fido, or /var/lib/nfc-fido as root)")
    p.add_argument("--success-sound", default=None,
                   help="optional sound file to play in the user's session on success")
    p.add_argument("--quiet", action="store_true", help="suppress diagnostics on stderr")
    args = p.parse_args()
    if args.pam:
        args.quiet = True

    try:
        user = resolve_user(args)
    except Exception as e:
        log(args, "could not resolve target user: %r" % e)
        return ERROR

    if args.skip_if_authtok and authtok_typed():
        log(args, "password supplied; skipping implant poll")
        return ABSENT

    try:
        result = verify(args, user)
    except Exception as e:
        log(args, "unexpected error: %r" % e)
        return ERROR

    if result == OK:
        beep(args, user)
        log(args, "verified implant for %s" % user)
    return result


if __name__ == "__main__":
    sys.exit(main())
